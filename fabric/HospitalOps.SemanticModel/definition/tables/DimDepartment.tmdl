table DimDepartment

	column DepartmentKey
		dataType: int64
		summarizeBy: none
		sourceColumn: DepartmentKey

	column DepartmentName
		dataType: string
		summarizeBy: none
		sourceColumn: DepartmentName

	partition DimDepartment = m
		mode: import
		source =
				let
				    Source = Sql.Database(SqlEndpoint, SqlDatabase),
				    Data = Source{[Schema="dbo",Item="dim_department"]}[Data]
				in
				    Data

