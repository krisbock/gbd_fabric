table EnvBanner

	column EnvironmentName
		dataType: string
		summarizeBy: none
		sourceColumn: EnvironmentName

	column RowMultiplier
		dataType: int64
		summarizeBy: sum
		sourceColumn: RowMultiplier

	column RefreshWindowDays
		dataType: int64
		summarizeBy: sum
		sourceColumn: RefreshWindowDays

	column EncounterCount
		dataType: int64
		summarizeBy: sum
		sourceColumn: EncounterCount

	column PatientCount
		dataType: int64
		summarizeBy: sum
		sourceColumn: PatientCount

	column ReadmissionRatePct
		dataType: double
		summarizeBy: none
		sourceColumn: ReadmissionRatePct

	column LoadTimestampUtc
		dataType: string
		summarizeBy: none
		sourceColumn: LoadTimestampUtc

	partition EnvBanner = m
		mode: import
		source =
				let
				    Source = Sql.Database(SqlEndpoint, SqlDatabase),
				    Data = Source{[Schema="dbo",Item="env_banner"]}[Data]
				in
				    Data

