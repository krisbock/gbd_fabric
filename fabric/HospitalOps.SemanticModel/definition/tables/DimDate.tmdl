table DimDate

	column DateKey
		dataType: int64
		summarizeBy: none
		sourceColumn: DateKey

	column Date
		dataType: string
		summarizeBy: none
		sourceColumn: Date

	column Year
		dataType: int64
		summarizeBy: none
		sourceColumn: Year

	column Month
		dataType: int64
		summarizeBy: none
		sourceColumn: Month

	column MonthName
		dataType: string
		summarizeBy: none
		sourceColumn: MonthName

	column Day
		dataType: int64
		summarizeBy: none
		sourceColumn: Day

	column DayOfWeek
		dataType: string
		summarizeBy: none
		sourceColumn: DayOfWeek

	column IsWeekend
		dataType: boolean
		summarizeBy: none
		sourceColumn: IsWeekend

	partition DimDate = m
		mode: import
		source =
				let
				    Source = Sql.Database(SqlEndpoint, SqlDatabase),
				    Data = Source{[Schema="dbo",Item="dim_date"]}[Data]
				in
				    Data

