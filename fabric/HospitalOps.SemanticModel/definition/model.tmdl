model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US

annotation PBI_QueryOrder = ["SqlEndpoint","SqlDatabase","EnvBanner","FactEncounter","DimDepartment","DimDate"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["TMDL-Extension","WebModelingEdit"]

ref table EnvBanner
ref table FactEncounter
ref table DimDepartment
ref table DimDate

